# Blaq Ceaser runtime shell placeholders
# Copy into a real runtime env file later when Eliza is installed.

# Model/runtime config later
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
MODEL_PROVIDER=openrouter
MODEL_NAME=meta-llama/llama-3.1-8b-instruct
OPENAI_SMALL_MODEL=meta-llama/llama-3.1-8b-instruct
OPENAI_LARGE_MODEL=meta-llama/llama-3.1-8b-instruct
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small
SECRET_SALT=

# Read-only data access later
SHARED_READONLY_SUPABASE_URL=
SHARED_READONLY_SUPABASE_ANON_KEY=

# Local Eliza runtime test
PGLITE_DATA_DIR=./.eliza/.elizadb
LOCAL_TEST_PROMPT=Explain the latest ETH signal without executing anything.

# Telegram connector later
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_TEST_CHAT_ID=
TELEGRAM_ALLOWED_TEST_THREAD_ID=
TELEGRAM_ALLOW_DIRECT_MESSAGES=false

# Safety intent
EXECUTION_AUTHORITY=ops-bot
READ_ONLY_MODE=true
