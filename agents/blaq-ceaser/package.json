{
  "name": "@nerdieblaq/blaq-ceaser",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -b",
    "start": "node --import tsx ./src/index.ts",
    "start:telegram:test": "node ./dist/telegram-test.js",
    "start:local": "node ./dist/local-dev.js",
    "dev:local": "node --import tsx ./src/local-dev.ts",
    "dev:local:env": "node --import tsx ./src/dev-local-env.ts",
    "dev:telegram:test": "node --import tsx ./src/telegram-test.ts",
    "dev:telegram:test:env": "node --import tsx ./src/dev-telegram-test-env.ts",
    "test:router": "node --import tsx ./src/router-regression.ts",
    "test:e2e:local": "node --import tsx ./src/local-e2e-regression-env.ts"
  },
  "dependencies": {
    "@elizaos/core": "^1.5.7",
    "@elizaos/plugin-bootstrap": "^1.5.7",
    "@elizaos/plugin-openai": "^1.0.11",
    "@elizaos/plugin-sql": "^1.0.0-alpha.43",
    "@elizaos/plugin-telegram": "^1.0.10",
    "@nerdieblaq/plugin-blaq-readonly": "file:./plugin-blaq-readonly"
  }
}
