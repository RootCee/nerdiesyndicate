{
  "name": "vite-typescript-starter-v5",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "agents/*",
    "agents/*/plugin-*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "build:blaq-ceaser": "tsc -b --clean packages/shared-readonly agents/blaq-ceaser/plugin-blaq-readonly agents/blaq-ceaser && tsc -b --force packages/shared-readonly agents/blaq-ceaser/plugin-blaq-readonly agents/blaq-ceaser",
    "dev:blaq-ceaser:local": "npm run -w @nerdieblaq/blaq-ceaser dev:local",
    "dev:blaq-ceaser:local:env": "npm run -w @nerdieblaq/blaq-ceaser dev:local:env",
    "dev:blaq-ceaser:telegram:test": "npm run -w @nerdieblaq/blaq-ceaser dev:telegram:test",
    "dev:blaq-ceaser:telegram:test:env": "npm run -w @nerdieblaq/blaq-ceaser dev:telegram:test:env",
    "start:blaq-ceaser:telegram:test": "npm run -w @nerdieblaq/blaq-ceaser start:telegram:test",
    "test:blaq-ceaser:router": "npm run -w @nerdieblaq/blaq-ceaser test:router",
    "test:blaq-ceaser:e2e:local": "npm run -w @nerdieblaq/blaq-ceaser test:e2e:local"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.90.21",
    "archiver": "^7.0.1",
    "ethers": "^5.5.2",
    "react": "^18.2",
    "react-dom": "^18.2",
    "react-router-dom": "^7.13.1",
    "stripe": "^22.0.0",
    "viem": "^2.47.2",
    "wagmi": "^2.19.5"
  },
  "engines": {
    "node": ">=22.x"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "vite": "^7.3.1"
  }
}
